# Block access to sensitive files when document root is the project root
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
<FilesMatch "^(composer\.(json|lock)|package(-lock)?\.json|phpunit\.xml|artisan|version\.txt)$">
    Require all denied
</FilesMatch>

# Block access to sensitive directories
<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteRule ^\.git - [F,L]
    RewriteRule ^vendor/ - [F,L]
    # Public uploads: /storage/* maps to the public disk (storage/app/public/*).
    # Try public/storage first (symlink from `php artisan storage:link`), then the real path.
    # Without the fallback, a missing/broken symlink (common after ZIP on shared hosting) caused
    # every /storage/* URL to hit the old blanket 403 below — broken profile & memorial images.
    RewriteCond %{DOCUMENT_ROOT}/public/storage/$1 -f
    RewriteRule ^storage/(.+)$ public/storage/$1 [L]

    RewriteCond %{DOCUMENT_ROOT}/storage/app/public/$1 -f
    RewriteRule ^storage/(.+)$ storage/app/public/$1 [L]
    RewriteRule ^database/ - [F,L]
    RewriteRule ^bootstrap/ - [F,L]
    RewriteRule ^config/ - [F,L]
    RewriteRule ^app/ - [F,L]
    RewriteRule ^routes/ - [F,L]
    RewriteRule ^resources/ - [F,L]
    RewriteRule ^tests/ - [F,L]

    # Rewrite root URL to public/
    RewriteRule ^$ public/index.php [L]

    # Rewrite all other requests to public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
